:80 {
    root * /usr/share/caddy
    file_server
    encode gzip zstd

    # Import generated redirects
    import /etc/caddy/redirects.caddy

    # Handle trailing slashes and index.html
    try_files {path} {path}/index.html {path}.html

    handle_errors {
        respond "{err.status_code} {err.status_text}"
    }
}
